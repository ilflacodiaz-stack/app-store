{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/tastes", "destination": "https://v0-restaurant-favorites-map-alfonso-diazs-projects.vercel.app/tastes", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
